{
    "name": "iserter/easy-lead-capture",
    "description": "Lightweight, embeddable lead capture system with SQLite storage, email notifications, and optional reCAPTCHA v3 protection.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "symfony/mailer": "^6.0|^7.0",
        "google/recaptcha": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Iserter\\EasyLeadCapture\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Iserter\\EasyLeadCapture\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
